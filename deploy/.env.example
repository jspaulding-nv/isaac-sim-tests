ISAAC_SIM_IMAGE=nvcr.io/nvidia/isaac-sim:6.0.1

# Use an address reachable by the browser. Keep this on a trusted private
# network because the viewer does not add authentication or TLS.
ISAACSIM_HOST=127.0.0.1
ISAACSIM_SIGNAL_PORT=49200
ISAACSIM_STREAM_PORT=48100
WEB_VIEWER_PORT=8210

# CDI selector: all, or a specific device index where supported.
GPU_DEVICE=all

# Relative paths resolve from deploy/.
ISAAC_SIM_DATA=./runtime/isaac-sim
ISAACSIM_HUB_CACHE_PATH=./runtime/hub
